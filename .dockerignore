# Git
.git
.gitignore

# 数据（通过volume持久化，不打包进镜像）
data/
# 注意: backend/models/ 中的LSTM模型文件需要打包进镜像(486KB)
# 不要排除 models/ 目录，否则Docker镜像内缺少lstm_best.pt

# Python缓存
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# IDE
.vscode/
.idea/
*.swp
*.swo

# 大型模型权重（通过entrypoint自动下载+volume持久化，不打包进镜像）
*.onnx
# initial_data缓存也不打包
initial_data/

# 系统文件
.DS_Store
Thumbs.db

# 部署脚本（运行时不需要打包）
deploy.sh
start.sh
typhoon-system.service

# 前端开发目录（使用static/中的构建结果）
frontend/

# Docker文件自身
Dockerfile
docker-compose.yml
.dockerignore
